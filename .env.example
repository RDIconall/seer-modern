# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional; set on Vercel to your canonical URL (Auth.js redirect URLs)
# AUTH_URL=https://your-project.vercel.app

# Optional single-user gate (lowercase email)
# ALLOWED_EMAIL=you@gmail.com

# Local sender overrides storage (defaults to .data/ in project root; use /tmp/seer on Vercel)
# SEER_DATA_DIR=.data

# Google Cloud Console → OAuth 2.0 Client (Web)
# Enable Gmail API. Authorized redirect: http://localhost:3000/api/auth/callback/google
# Scope includes gmail.modify (read, archive, trash, mark read)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Azure Portal → App registration → add Mail.Read (delegated) + openid, profile, email, offline_access
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Optional; default is multi-tenant "common"
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# AI triage + sentence refinement. Gemini is preferred (covered by Google AI
# Pro/Ultra monthly Cloud credits — claim Developer Program premium, then create
# a key at https://aistudio.google.com/apikey). Rules-only if no key is set.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest

# Legacy fallback provider, used only when GEMINI_API_KEY is unset
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
