# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional; set on Vercel to your canonical URL (Auth.js redirect URLs)
# AUTH_URL=https://your-project.vercel.app
# Desktop app: /   ·   Mobile PWA: /m (manifest start_url)

# Optional single-user gate (lowercase email)
# ALLOWED_EMAIL=you@gmail.com

# Local sender overrides storage (defaults to .data/ in project root; use /tmp/seer on Vercel)
# SEER_DATA_DIR=.data

# Google Cloud Console → OAuth 2.0 Client (Web)
# Enable Gmail API. Authorized redirect: http://localhost:3000/api/auth/callback/google
# Scopes: gmail.modify (read/archive/trash) + gmail.send (compose/reply)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Azure Portal → App registration → Mail.ReadWrite + Mail.Send (delegated)
# + openid, profile, email, offline_access, User.Read
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Optional; default is multi-tenant "common"
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# Gemini-first triage (preferred). Uses GEMINI_API_KEY or GOOGLE_GENERATIVE_AI_API_KEY,
# else Vercel AI Gateway (AI_GATEWAY_API_KEY / OIDC on Vercel).
# Behavior predictors: sign in again after upgrading to grant the new
# contacts + calendar + Google Docs read scopes (People API / Calendar API /
# Docs API on Google, Contacts.Read / Calendars.Read on Microsoft). Seer
# degrades gracefully without them. Your archive/trash actions are also
# learned per sender.
# AI memory: Settings → "About you" saves a plain-text profile
# (.data/profile-*.json) — pasted or imported from a Google Doc — that is
# appended to every Gemini triage call and reply draft.
# Cost controls: decisions are cached per message (.data/decisions-*.json),
# saved durably as native Gmail "Seer/<action>" labels (reviewed once,
# never re-paid — visible in Gmail too), obvious junk is decided by free
# local rules, and the static system prompt hits Gemini's implicit prompt
# caching. Bigger batches = fewer calls.
# GEMINI_API_KEY=
# Model auto-discovers via ListModels (Google retires ids); set to pin one.
# SEER_GEMINI_MODEL=
# SEER_GEMINI_BATCH_SIZE=25
# Every load scans the WHOLE inbox (paginated; ceiling below protects the
# 60s serverless budget on huge inboxes). Gemini spend per load is capped;
# unclassified overflow converges over the next refreshes.
# SEER_INBOX_SCAN=1000
# SEER_GEMINI_MAX_BATCHES=4
# "Delegate to EA" pre-fills this address on the AI-drafted handoff note.
# SEER_EA_EMAIL=
# AI_GATEWAY_API_KEY=

# Optional legacy OpenAI path for sentence NLP panel only
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
